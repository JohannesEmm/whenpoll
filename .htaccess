# Route root to landing page, slugs to vote page
Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On
    # Root → landing
    RewriteRule ^$ landing.php [L]
    # Clean slug URLs → vote.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^([a-z0-9_-]+)$ vote.php?id=$1 [L,QSA]
    # Block data dir
    RewriteRule ^data/ - [F,L]
</IfModule>

# Block direct access to internals
<FilesMatch "^(db\.php|config\.php|partials/.*)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "same-origin"
</IfModule>
